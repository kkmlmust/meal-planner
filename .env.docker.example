# ─── Telegram ───
# Get your bot token from @BotFather on Telegram
BOT_TOKEN=your-telegram-bot-token-here

# ─── Backend API ───
# Secret key used by the backend for Bearer token authentication
RECIPE_API_KEY=change-this-to-a-secure-random-string

# ─── PostgreSQL ───
POSTGRES_DB=recipe_db
POSTGRES_USER=recipe_user
POSTGRES_PASSWORD=change-this-to-a-secure-password

# ─── Ollama (Cloud LLM) ───
# Get your API key from https://ollama.com
OLLAMA_API_KEY=your-ollama-api-key-here
# Ollama cloud base URL (default: https://ollama.com/v1)
OLLAMA_BASE_URL=https://ollama.com/v1

# ─── Agent ───
RECIPE_AGENT_ACCESS_KEY=local-agent-key-change-this

# ─── Default Telegram ID (for --test mode) ───
DEFAULT_TELEGRAM_ID=test_user_1

# ─── LLM Model (Ollama cloud model) ───
# Examples: qwen2.5-coder:7b, llama3.1:8b, mistral:7b
RECIPE_AGENT_LLM_MODEL=qwen2.5-coder:7b
