# ─── Telegram ───
# Get your bot token from @BotFather on Telegram
BOT_TOKEN=your-telegram-bot-token-here

# ─── Backend API ───
# Secret key used by the backend for Bearer token authentication
RECIPE_API_KEY=change-this-to-a-secure-random-string

# ─── PostgreSQL ───
POSTGRES_DB=recipe_db
POSTGRES_USER=recipe_user
POSTGRES_PASSWORD=change-this-to-a-secure-password

# ─── Qwen Code API (OAuth — reuse your Qwen CLI auth) ───
# The qwen-code-api container reads OAuth creds from ~/.qwen/oauth_creds.json
# You only need to set this if you want a custom API key for the proxy itself.
# Authenticate once with: qwen (Qwen CLI) — it saves tokens to ~/.qwen/oauth_creds.json
QWEN_CODE_API_KEY=sk-qwen-local

# ─── Agent ───
RECIPE_AGENT_ACCESS_KEY=local-agent-key-change-this

# ─── Default Telegram ID (for --test mode) ───
DEFAULT_TELEGRAM_ID=test_user_1

# ─── LLM Model (passed to qwen-code-api) ───
RECIPE_AGENT_LLM_MODEL=coder-model
